# ============================================================
# SUPABASE
# ============================================================
# Usadas pelo app (cliente + servidor + middleware):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Pode ser o anon key clássico ou o publishable key público gerado pelo painel.
NEXT_PUBLIC_SUPABASE_ANON_KEY=anonkey
# Alternativa aceita pelo código para ambientes que já expõem esse nome:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Usada apenas no servidor (server actions / webhook):
SUPABASE_SERVICE_ROLE_KEY=yourservicerolekey
# Opcional — fallback de NEXT_PUBLIC_SUPABASE_URL no service role:
# SUPABASE_URL=https://your-project.supabase.co

# Somente desenvolvimento (ignorada quando NODE_ENV=production):
DEV_AUTO_GRANT_ADMIN=false

# ============================================================
# MERCADO PAGO (Orders API — PIX)
# ============================================================
# "Access Token" das credenciais de produção (APP_USR-...).
# É a ÚNICA credencial do painel que o app usa — Public Key,
# Client ID e Client Secret NÃO são necessários (não usamos
# SDK JS nem OAuth).
MELI_ACCESS_TOKEN=APP_USR-uuid

# "Assinatura secreta" da configuração de Webhooks
# (Suas integrações → Webhooks → Configurar notificações):
MERCADO_PAGO_WEBHOOK_SECRET=yourwebhooksecret

# ============================================================
# RESEND (email transacional do voucher)
# ============================================================
RESEND_API_KEY=yourresendapikey
RESEND_FROM_EMAIL=Secret Boutique <noreply@yourdomain.com>

# ============================================================
# WEB PUSH (notificações de pedido para ADMIN/STAFF)
# ============================================================
# Gere o par com: npx web-push generate-vapid-keys --json
# A pública é exposta ao navegador; a privada fica só no servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
# Contato exigido pelo protocolo VAPID (mailto: ou URL). Opcional.
# VAPID_SUBJECT=mailto:adm.apollo.log@protonmail.com

# ============================================================
# PRIVACIDADE / RATE LIMIT DE AVALIAÇÕES
# ============================================================
# Segredo usado para gerar o hash irreversível de IP nas
# avaliações anônimas. Obrigatório em produção.
REVIEW_IP_HASH_SECRET=change-me-to-a-long-random-secret

# ============================================================
# NOTAS
# ============================================================
# - Imagens de produto ficam no bucket 'products' do Supabase
#   Storage; o SQL guarda apenas referências (URLs), nunca binário.
# - Variáveis POSTGRES_* e SUPABASE_* extras injetadas pela
#   integração Vercel<->Supabase não são lidas pelo código.
